{% extends "base.html.twig" %}

{% block title %}Projets - TaskFlow{% endblock %}

{% block content %}
<div class="row">
    <div class="col-md-8">
        <h1>Mes Projets</h1>
    </div>
    <div class="col-md-4 text-end">
        {% if is_granted('ROLE_CHEF_PROJET') %}
            <a href="{{ path('projet_new') }}" class="btn btn-primary">
                + Créer un projet
            </a>
        {% endif %}
    </div>
</div>

{# Search Form #}
<div class="card mt-4 mb-4">
    <div class="card-body">
        <form method="GET" action="{{ path('projet_list') }}" class="row g-3">
            <div class="col-md-4">
                <input 
                    type="text" 
                    name="q" 
                    class="form-control" 
                    placeholder="🔍 Chercher par nom ou description..."
                    value="{{ query }}"
                >
            </div>
            <div class="col-md-3">
                <select name="statut" class="form-select">
                    <option value="">Tous les statuts</option>
                    <option value="planifie" {% if status == 'planifie' %}selected{% endif %}>🔵 Planifié</option>
                    <option value="en_cours" {% if status == 'en_cours' %}selected{% endif %}>🟡 En cours</option>
                    <option value="termine" {% if status == 'termine' %}selected{% endif %}>🟢 Terminé</option>
                    <option value="annule" {% if status == 'annule' %}selected{% endif %}>🔴 Annulé</option>
                </select>
            </div>
            <div class="col-md-3">
                <select name="sort" class="form-select">
                    <option value="nom" {% if sortBy == 'nom' %}selected{% endif %}>Nom (A-Z)</option>
                    <option value="dateCreation" {% if sortBy == 'dateCreation' %}selected{% endif %}>Date de création</option>
                    <option value="dateLimite" {% if sortBy == 'dateLimite' %}selected{% endif %}>Date limite</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary w-100">Chercher</button>
            </div>
            {% if query or status %}
                <div class="col-12">
                    <a href="{{ path('projet_list') }}" class="btn btn-sm btn-outline-secondary">Réinitialiser</a>
                </div>
            {% endif %}
        </form>
    </div>
</div>

{% if projets|length == 0 %}
    <div class="alert alert-info mt-4">
        <p>Aucun projet trouvé. {% if is_granted('ROLE_CHEF_PROJET') %}<a href="{{ path('projet_new') }}">Créez votre premier projet</a>.{% endif %}</p>
    </div>
{% else %}
    <table class="table table-striped table-hover mt-4">
        <thead class="table-dark">
            <tr>
                <th>Nom</th>
                <th>Statut</th>
                <th>Tâches</th>
                <th>Créateur</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for projet in projets %}
                <tr>
                    <td>
                        <strong>{{ projet.nom }}</strong>
                    </td>
                    <td>
                        {% if projet.statut == 'planifie' %}
                            <span class="badge bg-info">🔵 Planifié</span>
                        {% elseif projet.statut == 'en_cours' %}
                            <span class="badge bg-warning text-dark">🟡 En cours</span>
                        {% elseif projet.statut == 'termine' %}
                            <span class="badge bg-success">🟢 Terminé</span>
                        {% elseif projet.statut == 'annule' %}
                            <span class="badge bg-danger">🔴 Annulé</span>
                        {% endif %}
                    </td>
                    <td>
                        <span class="badge bg-secondary">{{ projet.taches|length }}</span>
                    </td>
                    <td>{{ projet.createur.pseudo }}</td>
                    <td>
                        <a href="{{ path('projet_detail', { id: projet.id }) }}" class="btn btn-sm btn-info">Voir</a>
                        {% if projet.createur == app.user or is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('projet_edit', { id: projet.id }) }}" class="btn btn-sm btn-warning">Modifier</a>
                            <form method="POST" action="{{ path('projet_delete', { id: projet.id }) }}" style="display: inline;" class="delete-form">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ projet.id) }}">
                                <button type="submit" class="btn btn-sm btn-danger delete-btn">Supprimer</button>
                            </form>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="mt-3 d-flex justify-content-center">
        {{ knp_pagination_render(projets) }}
    </div>
{% endif %}
{% endblock %}
