{% extends "base.html.twig" %}

{% block title %}Projets - TaskFlow{% endblock %}

{% block content %}
<div class="row">
    <div class="col-md-8">
        <h1>Mes Projets</h1>
    </div>
    <div class="col-md-4 text-end">
        {% if is_granted('ROLE_CHEF_PROJET') %}
            <a href="{{ path('projet_new') }}" class="btn btn-primary">
                + Créer un projet
            </a>
        {% endif %}
    </div>
</div>

{% if projets|length == 0 %}
    <div class="alert alert-info mt-4">
        <p>Aucun projet pour le moment. {% if is_granted('ROLE_CHEF_PROJET') %}<a href="{{ path('projet_new') }}">Créez votre premier projet</a>.{% endif %}</p>
    </div>
{% else %}
    <table class="table table-striped table-hover mt-4">
        <thead class="table-dark">
            <tr>
                <th>Nom</th>
                <th>Statut</th>
                <th>Tâches</th>
                <th>Créateur</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for projet in projets %}
                <tr>
                    <td>
                        <strong>{{ projet.nom }}</strong>
                    </td>
                    <td>
                        {% if projet.statut == 'planifie' %}
                            <span class="badge bg-info">🔵 Planifié</span>
                        {% elseif projet.statut == 'en_cours' %}
                            <span class="badge bg-warning text-dark">🟡 En cours</span>
                        {% elseif projet.statut == 'termine' %}
                            <span class="badge bg-success">🟢 Terminé</span>
                        {% elseif projet.statut == 'annule' %}
                            <span class="badge bg-danger">🔴 Annulé</span>
                        {% endif %}
                    </td>
                    <td>
                        <span class="badge bg-secondary">{{ projet.taches|length }}</span>
                    </td>
                    <td>{{ projet.createur.pseudo }}</td>
                    <td>
                        <a href="{{ path('projet_detail', { id: projet.id }) }}" class="btn btn-sm btn-info">Voir</a>
                        {% if projet.createur == app.user or is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('projet_edit', { id: projet.id }) }}" class="btn btn-sm btn-warning">Modifier</a>
                            <form method="POST" action="{{ path('projet_delete', { id: projet.id }) }}" style="display: inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ projet.id) }}">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Êtes-vous sûr de vouloir supprimer ce projet ?');">Supprimer</button>
                            </form>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endif %}
{% endblock %}
