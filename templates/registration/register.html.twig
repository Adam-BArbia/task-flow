{% extends 'base.html.twig' %}

{% block title %}Inscription - TaskFlow{% endblock %}

{% block content %}
<div class="row">
    <div class="col-md-6 mx-auto">
        <div class="card">
            <div class="card-body">
                <h1 class="card-title text-center mb-4">Créer un compte</h1>

                {{ form_start(registrationForm, { attr: { novalidate: 'novalidate' } }) }}
                    {% if form_errors(registrationForm) %}
                        <div class="alert alert-danger">
                            {{ form_errors(registrationForm) }}
                        </div>
                    {% endif %}

                    <div class="mb-3">
                        {{ form_row(registrationForm.email, {
                            label: 'Adresse e-mail',
                            attr: { class: 'form-control' }
                        }) }}
                    </div>

                    <div class="mb-3">
                        {{ form_row(registrationForm.pseudo, {
                            label: 'Nom d\'utilisateur',
                            attr: { class: 'form-control' }
                        }) }}
                    </div>

                    <div class="mb-3">
                        {{ form_row(registrationForm.plainPassword, {
                            label: 'Mot de passe',
                            attr: { class: 'form-control' }
                        }) }}
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Créer un compte</button>
                {{ form_end(registrationForm) }}

                <hr class="my-4">

                <div class="text-center">
                    <p>Vous avez déjà un compte ? <a href="{{ path('app_login') }}" class="btn btn-link">Se connecter</a></p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

