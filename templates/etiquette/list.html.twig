{% extends "base.html.twig" %}

{% block title %}Étiquettes - TaskFlow{% endblock %}

{% block content %}
<div class="row">
    <div class="col-md-8">
        <h1>Gestion des Étiquettes</h1>
    </div>
    <div class="col-md-4 text-end">
        <a href="{{ path('etiquette_new') }}" class="btn btn-primary">
            + Créer une étiquette
        </a>
    </div>
</div>

{% if etiquettes|length == 0 %}
    <div class="alert alert-info mt-4">
        <p>Aucune étiquette pour le moment. <a href="{{ path('etiquette_new') }}">Créez votre première étiquette</a>.</p>
    </div>
{% else %}
    <table class="table table-striped table-hover mt-4">
        <thead class="table-dark">
            <tr>
                <th>Nom</th>
                <th>Couleur</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for etiquette in etiquettes %}
                <tr>
                    <td>{{ etiquette.nom }}</td>
                    <td>
                        <span class="badge" style="background-color: {{ etiquette.couleur }};">
                            {{ etiquette.couleur }}
                        </span>
                    </td>
                    <td>
                        <form method="POST" action="{{ path('etiquette_delete', { id: etiquette.id }) }}" style="display: inline;" class="delete-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ etiquette.id) }}">
                            <button type="submit" class="btn btn-sm btn-danger delete-btn">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endif %}
{% endblock %}
